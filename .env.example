# ─────────────────────────────────────────────────────────────────────────────
# adbot secrets.  Copy to `.env` and fill in.  NEVER commit the real `.env`
# (it is gitignored).  Do NOT put real values in THIS file — it is committed.
# In Claude Code Routines / GitHub Actions, set these as environment variables /
# repo secrets instead.
# ─────────────────────────────────────────────────────────────────────────────

# Meta (Facebook) Marketing API — long-lived Business Manager System User token.
# Required scopes: ads_management, ads_read, business_management,
#                  pages_read_engagement (+ leads_retrieval if pulling leads).
META_SYSTEM_USER_TOKEN=EAAzKmyZCuwIMBRZCvjt4Xbg28FTe3i6cD4CM2vcmdIkAmf8OJnIHS1MLdtfIZAZCqae26WQv6uS5AXYcLKy95qp2MbRB91PqYiAFKNdoHDBlmjkWt01PEmVJh6ZCMBSKCGLqjrdEevZAK4f0vmGvax3mZCIlw8zAayoAYMjD5biYvvmYtLDmoAf0rWZBrRZCEnAZDZD

# Optional but recommended: the Meta App secret, used to sign Graph calls with
# appsecret_proof (defence-in-depth against token theft).
META_APP_SECRET=b22849ee9aa95a4dad7ab9850a5804e2

# Google service account with Drive + Docs APIs enabled. Share the Drive creatives
# folder + both Google Docs with this account's email.
# CLOUD (env vars are one line): supply the key as base64 — takes precedence if set:
#   base64 -w0 key.json        # macOS: base64 -i key.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON_B64=
# LOCAL alternative: a path to the JSON key file, OR the raw JSON contents inline.
GOOGLE_SERVICE_ACCOUNT_JSON=secrets/service-account.json

# Anthropic API key — used for caption/headline + creative-intelligence generation.
ANTHROPIC_API_KEY=XXXXXXXX
